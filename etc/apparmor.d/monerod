include <tunables/global>

# vim:syntax=apparmor


profile monerod /{home/nodo/bin,usr/bin}/monerod {
  include <abstractions/base>
  include <abstractions/nameservice>
  include <abstractions/openssl>
  include <abstractions/private-files-strict>

  capability dac_override,

  /media/monero/ rw,
  /sys/devices/platform/fe150000.pcie/pci0000:00/0000:00:00.0/0000:01:00.0/nvme/nvme0/** r,
  owner /media/monero/banlist.txt r,
  owner /media/monero/bitmonero/ rw,
  owner /media/monero/bitmonero/bitmonero.conf r,
  owner /media/monero/bitmonero/bitmonero.log rw,
  owner /media/monero/bitmonero/lmdb/ rw,
  owner /media/monero/bitmonero/lmdb/data.mdb rw,
  owner /media/monero/bitmonero/lmdb/lock.mdb rwk,
  owner /media/monero/bitmonero/p2pstate.bin{,.unportable} rw,
  owner /media/monero/bitmonero/poolstate.bin{,.unportable} rw,
  owner /media/monero/bitmonero/rpc_ssl.crt r,
  owner /media/monero/bitmonero/rpc_ssl.key r,
  owner /tmp/bitmonero.daemon.stdout.stderr rw,

}
